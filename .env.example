# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this to your actual Gemini API key.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_SECRET_TOKEN: Token to validate requests from the app to the server.
APP_SECRET_TOKEN="nakshatra-secure-token-2026"

# VITE_API_URL: Backend server URL (used by frontend)
VITE_API_URL="http://localhost:3001"

# VITE_APP_TOKEN: Must match APP_SECRET_TOKEN on the server
VITE_APP_TOKEN="nakshatra-secure-token-2026"

# NASA_API_KEY: Optional - for Astronomy Picture of the Day
# Get a free key at https://api.nasa.gov/
NASA_API_KEY="DEMO_KEY"
